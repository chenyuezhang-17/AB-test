# Twitter/X API (Alexia's account)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# TikHub API (for tweet search)
TIKHUB_API_KEY=

# Lessie CLI auth — run `lessie auth` first
# Lessie Web API — JWT from browser cookie for share link generation
LESSIE_JWT=

# Pipeline config
SCAN_KEYWORDS=looking for,anyone knows,recommend,hiring,need help finding
SCAN_INTERVAL_SECONDS=300
DRY_RUN=true
